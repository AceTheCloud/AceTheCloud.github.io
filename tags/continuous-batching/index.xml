&lt;text x="688" y="184" font-size="13" fill="#334155"&gt;&lt;tspan x="688" dy="0"&gt;Changes every step&lt;/tspan&gt;&lt;tspan x="688" dy="24"&gt;Maintain GPU occupancy&lt;/tspan&gt;&lt;tspan x="688" dy="24"&gt;&lt;/tspan&gt;&lt;/text&gt;
&lt;/g&gt;
&lt;line x1="300" y1="190" x2="338" y2="190" stroke="#64748b" stroke-width="3"/&gt;
