&lt;text x="532" y="212" font-size="20" font-family="Inter,Arial,sans-serif" font-weight="800" fill="#3730a3"&gt;Human review&lt;/text&gt;
&lt;text x="532" y="240" font-size="14" font-family="Inter,Arial,sans-serif" fill="#475569"&gt;rubrics + severity&lt;/text&gt;
&lt;rect x="860" y="175" width="230" height="90" rx="14" fill="#fff7ed" stroke="#f59e0b" stroke-width="2"/&gt;
&lt;text x="912" y="212" font-size="20" font-family="Inter,Arial,sans-serif" font-weight="800" fill="#9a3412"&gt;Prod signals&lt;/text&gt;
&lt;text x="912" y="240" font-size="14" font-family="Inter,Arial,sans-serif" fill="#475569"&gt;clicks, retries, edits&lt;/text&gt;
&lt;rect x="245" y="365" width="260" height="90" rx="14" fill="#ffffff" stroke="#cbd5e1" stroke-width="2"/&gt;
&lt;text x="300" y="402" font-size="20" font-family="Inter,Arial,sans-serif" font-weight="800" fill="#0f172a"&gt;Golden dataset&lt;/text&gt;
