&lt;marker id="arrow" markerWidth="10" markerHeight="10" refX="8" refY="4" orient="auto"&gt;&lt;path d="M0,0 L0,8 L9,4 z" fill="#64748b"/&gt;&lt;/marker&gt;
&lt;marker id="green-arrow" markerWidth="10" markerHeight="10" refX="8" refY="4" orient="auto"&gt;&lt;path d="M0,0 L0,8 L9,4 z" fill="#76B900"/&gt;&lt;/marker&gt;
