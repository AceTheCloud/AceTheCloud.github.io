&lt;text x="720" y="139" font-size="16" font-weight="800" fill="#047857"&gt;GPU execution&lt;/text&gt;
&lt;line x1="688" y1="158" x2="898" y2="158" stroke="#a7f3d0"/&gt;
&lt;text x="688" y="190" font-size="13" fill="#334155"&gt;&lt;tspan x="688" dy="0"&gt;Run one larger call&lt;/tspan&gt;&lt;tspan x="688" dy="24"&gt;Split responses&lt;/tspan&gt;&lt;tspan x="688" dy="24"&gt;&lt;/tspan&gt;&lt;/text&gt;
