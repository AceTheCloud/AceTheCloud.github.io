&lt;rect x="0" y="0" width="8" height="430" rx="4" fill="#06b6d4"/&gt;
&lt;text x="42" y="35" font-family="JetBrains Mono,monospace" font-size="11" font-weight="800" letter-spacing="1.4" fill="#0e7490"&gt;PHASE FIT&lt;/text&gt;
&lt;text x="42" y="68" font-family="Inter,Arial,sans-serif" font-size="24" font-weight="800" fill="#0f172a"&gt;Where Dynamic batching changes inference&lt;/text&gt;
&lt;g font-family="Inter,Arial,sans-serif"&gt;
&lt;rect x="42" y="104" width="405" height="188" rx="14" fill="#eff6ff" stroke="#60a5fa" stroke-width="2"/&gt;
