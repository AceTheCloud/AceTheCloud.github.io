&lt;rect x="355" y="105" width="250" height="172" rx="14" fill="#f5f3ff" stroke="#a78bfa" stroke-width="2"/&gt;
&lt;circle cx="383" cy="133" r="15" fill="#7c3aed"/&gt;&lt;text x="383" y="138" text-anchor="middle" font-size="11" font-weight="800" fill="#fff"&gt;02&lt;/text&gt;
&lt;text x="407" y="139" font-size="16" font-weight="800" fill="#6d28d9"&gt;Mixed scheduler&lt;/text&gt;
&lt;line x1="375" y1="158" x2="585" y2="158" stroke="#ddd6fe"/&gt;
&lt;text x="375" y="190" font-size="13" fill="#334155"&gt;&lt;tspan x="375" dy="0"&gt;Fit decode plus chunk&lt;/tspan&gt;&lt;tspan x="375" dy="24"&gt;Respect token budget&lt;/tspan&gt;&lt;tspan x="375" dy="24"&gt;&lt;/tspan&gt;&lt;/text&gt;
&lt;rect x="668" y="105" width="250" height="172" rx="14" fill="#ecfdf5" stroke="#34d399" stroke-width="2"/&gt;
&lt;circle cx="696" cy="133" r="15" fill="#059669"/&gt;&lt;text x="696" y="138" text-anchor="middle" font-size="11" font-weight="800" fill="#fff"&gt;03&lt;/text&gt;
&lt;text x="720" y="139" font-size="16" font-weight="800" fill="#047857"&gt;Completed prefill&lt;/text&gt;
&lt;line x1="688" y1="158" x2="898" y2="158" stroke="#a7f3d0"/&gt;
&lt;text x="688" y="190" font-size="13" fill="#334155"&gt;&lt;tspan x="688" dy="0"&gt;Join decode set&lt;/tspan&gt;&lt;tspan x="688" dy="24"&gt;Generate normally&lt;/tspan&gt;&lt;tspan x="688" dy="24"&gt;&lt;/tspan&gt;&lt;/text&gt;
&lt;/g&gt;
