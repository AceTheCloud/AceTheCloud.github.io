&lt;path d="M651 185 L663 191 L651 197 Z" fill="#64748b"/&gt;
&lt;rect x="42" y="310" width="876" height="42" rx="10" fill="#f1f5f9"/&gt;
&lt;text x="480" y="336" text-anchor="middle" font-family="JetBrains Mono,monospace" font-size="12" fill="#64748b"&gt;INPUT → TRANSFORM → OUTCOME&lt;/text&gt;
