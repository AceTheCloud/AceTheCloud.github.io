&lt;rect x="588" y="180" width="190" height="86" rx="14" fill="#fff7ed" stroke="#f59e0b" stroke-width="2"/&gt;
&lt;text x="630" y="216" font-size="19" font-family="Inter,Arial,sans-serif" font-weight="800" fill="#9a3412"&gt;Context&lt;/text&gt;
&lt;text x="620" y="242" font-size="14" font-family="Inter,Arial,sans-serif" fill="#475569"&gt;chunk quality&lt;/text&gt;
&lt;path d="M788 223 H840" stroke="#64748b" stroke-width="3" marker-end="url(#arrow)"/&gt;
&lt;rect x="854" y="180" width="190" height="86" rx="14" fill="#111827"/&gt;
&lt;text x="896" y="216" font-size="19" font-family="Inter,Arial,sans-serif" font-weight="800" fill="#ffffff"&gt;Answer&lt;/text&gt;
&lt;text x="890" y="242" font-size="14" font-family="Inter,Arial,sans-serif" fill="#bbf7d0"&gt;faithful, useful&lt;/text&gt;
