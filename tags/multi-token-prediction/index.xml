&lt;text x="42" y="68" font-family="Inter,Arial,sans-serif" font-size="24" font-weight="800" fill="#0f172a"&gt;Parallel Decoding: request path&lt;/text&gt;
&lt;g font-family="Inter,Arial,sans-serif"&gt;
&lt;rect x="42" y="105" width="250" height="172" rx="14" fill="#eff6ff" stroke="#60a5fa" stroke-width="2"/&gt;
&lt;circle cx="70" cy="133" r="15" fill="#2563eb"/&gt;&lt;text x="70" y="138" text-anchor="middle" font-size="11" font-weight="800" fill="#fff"&gt;01&lt;/text&gt;
&lt;text x="94" y="139" font-size="16" font-weight="800" fill="#1d4ed8"&gt;Current prefix&lt;/text&gt;
&lt;line x1="62" y1="158" x2="272" y2="158" stroke="#bfdbfe"/&gt;
&lt;text x="62" y="190" font-size="13" fill="#334155"&gt;&lt;tspan x="62" dy="0"&gt;Multiple decode heads&lt;/tspan&gt;&lt;tspan x="62" dy="24"&gt;Propose token tree&lt;/tspan&gt;&lt;tspan x="62" dy="24"&gt;&lt;/tspan&gt;&lt;/text&gt;
&lt;rect x="355" y="105" width="250" height="172" rx="14" fill="#f5f3ff" stroke="#a78bfa" stroke-width="2"/&gt;
&lt;circle cx="383" cy="133" r="15" fill="#7c3aed"/&gt;&lt;text x="383" y="138" text-anchor="middle" font-size="11" font-weight="800" fill="#fff"&gt;02&lt;/text&gt;
&lt;text x="407" y="139" font-size="16" font-weight="800" fill="#6d28d9"&gt;Tree attention&lt;/text&gt;
&lt;line x1="375" y1="158" x2="585" y2="158" stroke="#ddd6fe"/&gt;
&lt;text x="375" y="190" font-size="13" fill="#334155"&gt;&lt;tspan x="375" dy="0"&gt;Verify candidates&lt;/tspan&gt;&lt;tspan x="375" dy="24"&gt;Find accepted path&lt;/tspan&gt;&lt;tspan x="375" dy="24"&gt;&lt;/tspan&gt;&lt;/text&gt;
&lt;rect x="668" y="105" width="250" height="172" rx="14" fill="#ecfdf5" stroke="#34d399" stroke-width="2"/&gt;
&lt;circle cx="696" cy="133" r="15" fill="#059669"/&gt;&lt;text x="696" y="138" text-anchor="middle" font-size="11" font-weight="800" fill="#fff"&gt;03&lt;/text&gt;
&lt;text x="720" y="139" font-size="16" font-weight="800" fill="#047857"&gt;Committed output&lt;/text&gt;
&lt;line x1="688" y1="158" x2="898" y2="158" stroke="#a7f3d0"/&gt;
&lt;text x="688" y="190" font-size="13" fill="#334155"&gt;&lt;tspan x="688" dy="0"&gt;Append valid tokens&lt;/tspan&gt;&lt;tspan x="688" dy="24"&gt;Discard other branches&lt;/tspan&gt;&lt;tspan x="688" dy="24"&gt;&lt;/tspan&gt;&lt;/text&gt;
&lt;/g&gt;
&lt;line x1="300" y1="191" x2="338" y2="191" stroke="#64748b" stroke-width="3"/&gt;
&lt;path d="M338 185 L350 191 L338 197 Z" fill="#64748b"/&gt;
&lt;line x1="613" y1="191" x2="651" y2="191" stroke="#64748b" stroke-width="3"/&gt;
&lt;path d="M651 185 L663 191 L651 197 Z" fill="#64748b"/&gt;
&lt;rect x="42" y="310" width="876" height="42" rx="10" fill="#f1f5f9"/&gt;
&lt;text x="480" y="336" text-anchor="middle" font-family="JetBrains Mono,monospace" font-size="12" fill="#64748b"&gt;INPUT → TRANSFORM → OUTCOME&lt;/text&gt;
