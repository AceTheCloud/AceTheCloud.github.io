&lt;text x="688" y="184" font-size="13" fill="#334155"&gt;&lt;tspan x="688" dy="0"&gt;Shard rows&lt;/tspan&gt;&lt;tspan x="688" dy="24"&gt;Continue together&lt;/tspan&gt;&lt;tspan x="688" dy="24"&gt;&lt;/tspan&gt;&lt;/text&gt;
&lt;/g&gt;
